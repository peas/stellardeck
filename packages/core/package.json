{
  "name": "@stellardeck/core",
  "version": "0.0.1",
  "description": "StellarDeck engine: Deckset-compatible markdown parser, autoflow layout inference, deck health diagnostics.",
  "license": "MIT",
  "private": true,
  "type": "commonjs",
  "main": "src/index.js",
  "types": "src/types.d.ts",
  "exports": {
    ".": {
      "require": "./src/index.js",
      "import": "./src/index.mjs"
    },
    "./autoflow": "./src/autoflow.js",
    "./parser": "./src/deckset-parser.js",
    "./diagnostics": "./src/diagnostics.js",
    "./constants": "./src/constants.js",
    "./print-mode": "./src/print-mode.js",
    "./browser-globals": "./dist/browser-globals.global.js"
  },
  "files": [
    "src",
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "tsup"
  },
  "keywords": [
    "presentation",
    "markdown",
    "deckset",
    "autoflow"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/peas/stellardeck.git",
    "directory": "packages/core"
  },
  "homepage": "https://stellardeck.dev",
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
