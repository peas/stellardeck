{
  "name": "vscode-stellardeck",
  "displayName": "StellarDeck",
  "description": "Preview StellarDeck markdown presentations in VS Code",
  "version": "0.1.0",
  "publisher": "stellardeck",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/peas/stellardeck.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": ["Visualization", "Other"],
  "keywords": ["markdown", "presentation", "slides", "deckset", "stellardeck"],
  "main": "./extension.js",
  "activationEvents": ["onLanguage:markdown"],
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./styles/slides2.css",
      "./styles/layout.css",
      "./styles/themes.css",
      "./styles/preview-wrapper.css"
    ],
    "markdown.previewScripts": [
      "./preview/fittext-preview.js"
    ]
  }
}
